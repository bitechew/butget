{
  "version": 2,
  "functions": {
    "api/index.php": { 
      "runtime": "vercel-php@0.9.0",
      "includeFiles": [
        "bootstrap/**",
        "config/**",
        "routes/**",
        "app/**",
        "resources/**"
      ]
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}